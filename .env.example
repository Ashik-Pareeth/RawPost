# ─────────────────────────────────────────────
# RAWPOST — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.

# ── Site ──────────────────────────────────────
# The canonical URL of the deployed site (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://rawpost.com

# ── Analytics ─────────────────────────────────
# Google Analytics 4 Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# ── Newsletter ────────────────────────────────
# ConvertKit API key (server-side only — do NOT prefix with NEXT_PUBLIC_)
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# ── Security ──────────────────────────────────
# Rate-limit window in seconds (default: 60)
RATE_LIMIT_WINDOW=60
# Max requests per window per IP (default: 5)
RATE_LIMIT_MAX=5

# ── Contact form ──────────────────────────────
# Resend API key for sending contact emails (server-side only)
RESEND_API_KEY=
CONTACT_TO_EMAIL=hello@rawpost.com
